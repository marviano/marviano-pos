{
  "name": "marviano-pos",
  "version": "0.1.12",
  "description": "Pictos Point of Sale System",
  "private": true,
  "main": "dist/electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron-dev": "cross-env PORT=3000 concurrently -n \"NEXT,ELECTRON\" -c \"blue,green\" \"cross-env PORT=3000 node scripts/dev-server-filter.js\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-dev:3001": "cross-env PORT=3001 concurrently \"cross-env PORT=3001 npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "electron-dev:3002": "cross-env PORT=3002 concurrently \"cross-env PORT=3002 npm run dev\" \"wait-on http://localhost:3002 && electron .\"",
    "electron-dev:3301": "cross-env PORT=3301 concurrently \"cross-env PORT=3301 npm run dev\" \"wait-on http://localhost:3301 && electron .\"",
    "electron-pack": "npm run build && electron-builder",
    "build-electron": "tsc -p electron/tsconfig.json",
    "version:bump": "node scripts/bump-version.js",
    "dist": "npm run build-electron && npm run build && node scripts/fix-nested-html-paths.js && electron-builder --publish=never",
    "dist:release": "node scripts/bump-version.js && npm run dist",
    "dist-clean": "node -e \"const fs=require('fs');const cp=require('child_process');if(fs.existsSync('dist-electron')){fs.rmSync('dist-electron',{recursive:true,force:true});}cp.execSync('npm run build-electron',{stdio:'inherit'});cp.execSync('npm run build',{stdio:'inherit'});cp.execSync('node scripts/fix-nested-html-paths.js',{stdio:'inherit'});cp.execSync('npx electron-builder --publish=never',{stdio:'inherit'});\"",
    "dist:release-clean": "node scripts/bump-version.js && npm run dist-clean",
    "build-icon": "node scripts/convert-icon.js"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "dotenv": "^16.4.5",
    "jspdf": "^4.2.0",
    "jspdf-autotable": "^5.0.7",
    "mysql2": "^3.15.3",
    "node-thermal-printer": "^4.4.5",
    "ws": "^8.18.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/electron": "^1.4.38",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^38.8.6",
    "electron-builder": "26.0.1",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "lucide-react": "^0.545.0",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.pos.app",
    "productName": "Pictos",
    "directories": {
      "output": "dist-electron"
    },
    "compression": "maximum",
    "files": [
      "dist/**/*",
      "out/**/*",
      "out/_next/**/*",
      "public/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "ia32"
          ]
        }
      ],
      "icon": "public/256x256.png",
      "forceCodeSigning": false
    },
    "mac": {
      "icon": "public/logo/Momoyo.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "icon": "public/logo/Momoyo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}

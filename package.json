{
  "name": "marviano-pos",
  "version": "0.1.0",
  "description": "Marviano Point of Sale System",
  "private": true,
  "main": "dist/electron/main.js",
  "homepage": "./",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "electron": "electron .",
    "electron-dev": "cross-env PORT=3000 concurrently -n \"NEXT,ELECTRON\" -c \"blue,green\" \"cross-env PORT=3000 node scripts/dev-server-filter.js\" \"wait-on http://localhost:3000 && electron .\"",
    "electron-dev:3001": "cross-env PORT=3001 concurrently \"cross-env PORT=3001 npm run dev\" \"wait-on http://localhost:3001 && electron .\"",
    "electron-dev:3002": "cross-env PORT=3002 concurrently \"cross-env PORT=3002 npm run dev\" \"wait-on http://localhost:3002 && electron .\"",
    "electron-pack": "npm run build && electron-builder",
    "build-electron": "tsc -p electron/tsconfig.json",
    "rebuild-native": "@electron/rebuild -f -w better-sqlite3",
    "dist": "npm run build-electron && npm run build && node scripts/fix-nested-html-paths.js && electron-builder --publish=never",
    "dist-clean": "if exist dist-electron rmdir /s /q dist-electron 2>nul & npm run build-electron && npm run build && node scripts/fix-nested-html-paths.js && electron-builder --publish=never"
  },
  "dependencies": {
    "bcryptjs": "^3.0.2",
    "better-sqlite3": "^12.5.0",
    "dotenv": "^16.4.5",
    "mysql2": "^3.15.3",
    "node-thermal-printer": "^4.4.5",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "lucide-react": "^0.545.0",
    "@electron/rebuild": "^4.0.1",
    "@eslint/eslintrc": "^3",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/electron": "^1.4.38",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "concurrently": "^9.2.1",
    "cross-env": "^7.0.3",
    "electron": "^38.2.2",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "wait-on": "^9.0.1"
  },
  "build": {
    "appId": "com.marviano.pos",
    "productName": "Marviano POS",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "out/**/*",
      "out/_next/**/*",
      "public/**/*",
      "scripts/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/app.ico",
      "forceCodeSigning": false
    },
    "mac": {
      "icon": "public/logo/Momoyo.png",
      "category": "public.app-category.business"
    },
    "linux": {
      "icon": "public/logo/Momoyo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}